# LINARES configuration
# Copy this file to .env and fill in your values.

# Hugging Face token — required to download the sentence-transformer model.
# Get yours at: https://huggingface.co/settings/tokens - it's free!
HF_TOKEN=your_token_here

# TMDB API key — required for fetching movie plots, posters, and metadata.
# Register and get your free key at: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_key_here

# Minimum IMDb vote count for a movie to be included in the catalog.
# Lower values = larger catalog but more obscure titles. Default: 10000.
# MIN_VOTES=10000

# How many movies to pre-fetch plots/posters for during initial setup.
# The rest can be enriched incrementally with fetch_metadata.py. Default: 1000.
# SETUP_FETCH_LIMIT=1000

# Allowed CORS origins for the API (comma-separated).
# Defaults to "*" (open) when not set, which is fine for local use.
# Set this to your frontend URL for non-local deployments.
# Example: ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com
# ALLOWED_ORIGINS=*
